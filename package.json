{
  "name": "portfolio-worker",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "test": "jest",
    "evals": "node src/evals/runMockEvals.js",
    "evals:real": "node src/evals/runRealEvals.js"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(resend)/)"
    ]
  },
  "babel": {
    "presets": [
      [
        "@babel/preset-env",
        {
          "targets": {
            "node": "current"
          }
        }
      ]
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "babel-jest": "^29.0.0",
    "jest": "^29.0.0",
    "wrangler": "^4.98.0"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.3",
    "resend": "^6.12.4"
  }
}
